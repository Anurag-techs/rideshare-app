# ─── RideShare — Example environment variables ────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is excluded via .gitignore.

PORT=3000
JWT_SECRET=replace_with_a_long_random_string

# Database (SQLite path — switch to PostgreSQL URL for production)
DB_PATH=./database.sqlite

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Razorpay Keys ────────────────────────────────────────────────────────────
# Use rzp_test_... for development, rzp_live_... for production.
# Get your keys from: https://dashboard.razorpay.com/app/keys
# ⚠️  Rotate immediately if ever exposed.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ─── OpenAI (optional — AI features work in mock mode without this) ────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# Commission rate — platform takes 10% per ride
COMMISSION_RATE=0.10

# ─── Admin secret for wallet management endpoints ──────────────────────────────
ADMIN_SECRET=replace_with_a_strong_random_string

# ─── Surge pricing ─────────────────────────────────────────────────────────────
# Set SURGE_ENABLED=false to disable surge pricing entirely
SURGE_ENABLED=true
SURGE_PEAK_MULTIPLIER=1.2   # 1.2 = +20% during peak hours (8-11am, 6-9pm)

# ─── Withdrawal fee ────────────────────────────────────────────────────────────
WITHDRAWAL_FEE=10            # ₹10 flat fee per withdrawal request

# ─── Referral bonus ────────────────────────────────────────────────────────────
REFERRAL_BONUS=50            # ₹50 wallet credit for referrer when friend completes first booking

# ─── For production PostgreSQL ─────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/rideshare
